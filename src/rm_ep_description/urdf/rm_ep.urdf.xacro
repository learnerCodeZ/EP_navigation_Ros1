<?xml version="1.0"?>
<robot name="robomaster_ep" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========== 材质定义 ========== -->
  <material name="chassis_grey">
    <color rgba="0.3 0.3 0.35 1.0"/>
  </material>
  <material name="wheel_black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="laser_blue">
    <color rgba="0.1 0.3 0.8 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.95 0.95 0.95 1.0"/>
  </material>

  <!-- ========== 宏: 麦克纳姆轮 ========== -->
  <xacro:macro name="mecanum_wheel" params="name pos_x pos_y pos_z">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${pos_x} ${pos_y} ${pos_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ========== 底盘参数 ========== -->
  <xacro:property name="chassis_length" value="0.28"/>
  <xacro:property name="chassis_width" value="0.22"/>
  <xacro:property name="chassis_height" value="0.10"/>
  <xacro:property name="chassis_clearance" value="0.045"/>

  <xacro:property name="wheel_radius" value="0.0485"/>
  <xacro:property name="wheel_width" value="0.04"/>
  <xacro:property name="wheel_base" value="0.24"/>
  <xacro:property name="wheel_track" value="0.18"/>

  <!-- 激光雷达安装位置 (底盘顶部最前方居中) -->
  <xacro:property name="laser_x" value="0.11"/>
  <xacro:property name="laser_z" value="0.10"/>

  <!-- ========== base_link ========== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="chassis_grey"/>
    </visual>
    <visual>
      <!-- 顶部白色装饰板 -->
      <origin xyz="0 0 ${chassis_height/2 + 0.002}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length - 0.04} ${chassis_width - 0.04} 0.004"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <!-- ========== imu_link (HI12 外置 IMU) ========== -->
  <link name="imu_link"/>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <!-- HI12 安装位置: 长度中间 (x=0)，右侧偏 6cm (y=-0.06)，底盘顶部 (z=0.10)
         模块 X 轴朝前、Y 轴朝左、Z 轴朝上，与 base_link 对齐，rpy=0 -->
    <origin xyz="0 -0.06 0.10" rpy="0 0 0"/>
  </joint>

  <!-- ========== laser_link (RPLIDAR A2 安装位置) ========== -->
  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.04"/>
      </geometry>
      <material name="laser_blue"/>
      </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="${laser_x} 0 ${chassis_height/2 + laser_z}" rpy="0 0 0"/>
  </joint>

  <!-- ========== 四个麦克纳姆轮 ========== -->
  <xacro:property name="pos_z" value="${-chassis_height/2 + wheel_radius + chassis_clearance}"/>

  <xacro:mecanum_wheel name="wheel_fl" pos_x="${wheel_base/2}" pos_y="${wheel_track/2}" pos_z="${pos_z}"/>
  <xacro:mecanum_wheel name="wheel_fr" pos_x="${wheel_base/2}" pos_y="${-wheel_track/2}" pos_z="${pos_z}"/>
  <xacro:mecanum_wheel name="wheel_rl" pos_x="${-wheel_base/2}" pos_y="${wheel_track/2}" pos_z="${pos_z}"/>
  <xacro:mecanum_wheel name="wheel_rr" pos_x="${-wheel_base/2}" pos_y="${-wheel_track/2}" pos_z="${pos_z}"/>

</robot>
