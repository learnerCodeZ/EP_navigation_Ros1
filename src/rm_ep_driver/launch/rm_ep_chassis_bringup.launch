<launch>
  <!-- RoboMaster EP 底盘驱动 (基于 ROS2 移植) -->
  <arg name="ep_sn" default="3JKDH3B001891M" doc="RoboMaster EP 序列号 (SN)"/>
  <arg name="ep_conn_type" default="rndis" doc="连接模式: ap(WiFi直连) / sta(路由器) / rndis(USB)"/>
  <arg name="ep_ip" default="" doc="EP IP地址"/>
  <arg name="enable_cmd_vel" default="true" doc="是否启用速度控制"/>
  <arg name="enable_imu" default="false" doc="是否启用 EP 内置 IMU（使用 HI12 时设为 false）"/>
  <arg name="odom_rate" default="20" doc="里程计频率 (Hz)"/>

  <node name="rm_ep_chassis_driver" pkg="rm_ep_driver" type="rm_ep_driver_node.py" output="screen" required="true">
    <rosparam file="$(find rm_ep_driver)/config/rm_ep_params.yaml" command="load"/>
    <param name="ep_sn" value="$(arg ep_sn)" unless="$(eval arg('ep_sn') == '')"/>
    <param name="ep_conn_type" value="$(arg ep_conn_type)"/>
    <param name="ep_ip" value="$(arg ep_ip)" unless="$(eval arg('ep_ip') == '')"/>
    <param name="enable_cmd_vel" value="$(arg enable_cmd_vel)"/>
    <param name="enable_imu" value="$(arg enable_imu)"/>
    <param name="odom_rate" value="$(arg odom_rate)"/>
  </node>
</launch>
