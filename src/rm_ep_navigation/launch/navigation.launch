<launch>
  <!-- ============================================ -->
  <!-- 导航模式: AMCL + move_base                  -->
  <!-- ============================================ -->

  <!-- 参数 -->
  <arg name="ep_sn" default="3JKDH3B001891M" doc="RoboMaster EP 序列号"/>
  <arg name="ep_conn_type" default="rndis" doc="连接模式: ap(WiFi直连) / sta(路由器) / rndis(USB)"/>
  <arg name="ep_ip" default="" doc="EP IP 地址"/>
  <arg name="lidar_frame" default="laser_link" doc="激光雷达 TF 帧名"/>
  <arg name="serial_port" default="/dev/ttyUSB0" doc="激光雷达串口号"/>
  <arg name="map_file" default="$(find rm_ep_navigation)/maps/default_map.yaml" doc="地图文件路径"/>
  <arg name="rviz" default="true" doc="是否启动 RVIZ"/>

  <!-- ========== 1. 机器人模型 (URDF + TF) ========== -->
  <include file="$(find rm_ep_description)/launch/description.launch"/>

  <!-- ========== 2. RPLIDAR A2 激光雷达驱动 ========== -->
  <node name="rplidarNode" pkg="rplidar_ros" type="rplidarNode" output="screen">
    <param name="serial_port"     type="string" value="$(arg serial_port)"/>
    <param name="serial_baudrate" type="int"    value="256000"/>
    <param name="frame_id"        type="string" value="$(arg lidar_frame)"/>
    <param name="inverted"        type="bool"   value="false"/>
    <param name="angle_compensate" type="bool"  value="true"/>
  </node>

  <!-- ========== 3. RoboMaster EP 驱动 ========== -->
  <include file="$(find rm_ep_driver)/launch/rm_ep_chassis_bringup.launch">
    <arg name="ep_sn" value="$(arg ep_sn)"/>
    <arg name="ep_conn_type" value="$(arg ep_conn_type)"/>
    <arg name="ep_ip" value="$(arg ep_ip)"/>
    <arg name="enable_cmd_vel" value="true"/>
  </include>

  <!-- ========== 4. robot_localization EKF 融合 ========== -->
  <node name="ekf_localization" pkg="robot_localization" type="ekf_localization_node" output="screen">
    <rosparam file="$(find rm_ep_navigation)/config/ekf.yaml" command="load"/>
  </node>

  <!-- ========== 5. map_server 加载地图 ========== -->
  <node name="map_server" pkg="map_server" type="map_server"
        args="$(arg map_file)"/>

  <!-- ========== 6. AMCL 定位 ========== -->
  <node name="amcl" pkg="amcl" type="amcl" output="screen">
    <rosparam file="$(find rm_ep_navigation)/config/amcl_params.yaml" command="load"/>
    <remap from="scan" to="/scan"/>
  </node>

  <!-- ========== 7. move_base 导航框架 ========== -->
  <node name="move_base" pkg="move_base" type="move_base" output="screen">
    <rosparam file="$(find rm_ep_navigation)/config/costmap_common_params.yaml" command="load" ns="global_costmap"/>
    <rosparam file="$(find rm_ep_navigation)/config/costmap_common_params.yaml" command="load" ns="local_costmap"/>
    <rosparam file="$(find rm_ep_navigation)/config/global_costmap_params.yaml" command="load"/>
    <rosparam file="$(find rm_ep_navigation)/config/local_costmap_params.yaml" command="load"/>
    <rosparam file="$(find rm_ep_navigation)/config/teb_local_planner_params.yaml" command="load"/>
    <rosparam file="$(find rm_ep_navigation)/config/move_base_params.yaml" command="load"/>
    <remap from="scan" to="/scan"/>
  </node>

  <!-- ========== 8. RVIZ 可视化 ========== -->
  <node if="$(arg rviz)" name="rviz" pkg="rviz" type="rviz"
        args="-d $(find rm_ep_navigation)/rviz/nav.rviz"/>
</launch>
